# En production : APP_ENV=production et APP_DEBUG=false (les erreurs sont alors journalisees dans storage/logs)
# Deploiement Render : voir DEPLOY_RENDER.md (MySQL externe gratuit requis)
APP_NAME=BarFlow
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost/barflow/public
APP_TIMEZONE=Africa/Douala
SESSION_TIMEOUT_MINUTES=120
REMEMBER_ME_DAYS=15

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=barflow
DB_USERNAME=root
DB_PASSWORD=
